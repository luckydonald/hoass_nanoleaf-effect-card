{
  "name": "plugin-template-card",
  "version": "0.0.0-dev0",
  "description": "Lovelace card for Plugin Template for Home Assistant",
  "main": "dist/plugin-template-card.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/luckydonald/hoass_plugin-template.git"
  },
  "author": "luckydonald",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc -b",
    "format": "dprint fmt",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint \"**/*.{ts,js,vue}\" --quiet",
    "lint:fix": "eslint \"**/*.{ts,js,vue}\" --fix"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "dprint": "^0.51.1",
    "eslint": "^9.39.2",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-vue": "^10.7.0",
    "jsdom": "^27.4.0",
    "sass-embedded": "^1.8.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  }
}
